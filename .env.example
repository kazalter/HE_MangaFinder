# Docker Compose / Dockge
MANGAFINDER_PORT=8000
MANGAFINDER_DATA_DIR=./data
# 可设为 /mnt/hdd/mangafinder/downloads，将大体积 CBZ 与数据库分盘保存。
MANGAFINDER_DOWNLOADS_HOST_DIR=./data/downloads
# 封面缓存建议与下载文件一起放在 HDD。
MANGAFINDER_COVER_CACHE_HOST_DIR=./data/cover-cache
# 社交媒体与 OCR 缓存也建议放到 HDD。
MANGAFINDER_SOCIAL_MEDIA_HOST_DIR=./data/social-media
TZ=Etc/UTC

# MangaFinder application
MANGAFINDER_DATABASE_URL=sqlite:///./data/mangafinder.db
MANGAFINDER_POLL_INTERVAL_SECONDS=2
MANGAFINDER_MAX_JOB_ATTEMPTS=3
MANGAFINDER_CORS_ORIGINS=http://localhost:5173
MANGAFINDER_DOWNLOADS_DIR=./data/downloads
MANGAFINDER_COVER_CACHE_DIR=./data/cover-cache
MANGAFINDER_USE_DATA_SAVER=true
MANGAFINDER_CHAPTER_LANGUAGES=zh-hans,zh-hant,en,ja
MANGAFINDER_USER_AGENT=MangaFinder/0.1

# WNACG：会按顺序尝试主域与官方发布页镜像。Cookie 可留空。
MANGAFINDER_WNACG_BASE_URLS=https://www.wnacg.com,https://www.wn08.cfd,https://www.wn07.cfd,https://www.wn08.shop,https://www.wn07.shop
MANGAFINDER_WNACG_COOKIE=
MANGAFINDER_WNACG_MAX_SEARCH_PAGES=5

# nHentai：使用 gallery JSON 获取元数据；403 时配置独立代理或浏览器会话 Cookie。
MANGAFINDER_NHENTAI_ENABLED=true
MANGAFINDER_NHENTAI_BASE_URL=https://nhentai.net
MANGAFINDER_NHENTAI_PROXY_URL=
MANGAFINDER_NHENTAI_COOKIE=
MANGAFINDER_NHENTAI_MAX_SEARCH_PAGES=10
# 仅在宿主机代理通过专用 Docker 网络转发时使用。
MANGAFINDER_PROXY_NETWORK=he-manager_default

# 聚合 Agent：Phase 1 只生成审核建议，不会自动合并，也不会发送封面图片。
# 宿主机 Ollama 示例：http://host.docker.internal:11434/v1
MANGAFINDER_AGENT_ENABLED=false
MANGAFINDER_AGENT_PROVIDER=openai_compatible
MANGAFINDER_AGENT_BASE_URL=http://host.docker.internal:11434/v1
MANGAFINDER_AGENT_MODEL=
MANGAFINDER_AGENT_API_KEY=
MANGAFINDER_AGENT_TEMPERATURE=0
MANGAFINDER_AGENT_TIMEOUT_SECONDS=60
MANGAFINDER_AGENT_MAX_REVIEWS_PER_RUN=20
MANGAFINDER_AGENT_REVIEW_AFTER_DISCOVERY=false
MANGAFINDER_AGENT_AUTO_APPLY=false
MANGAFINDER_AGENT_AUTO_APPLY_THRESHOLD=0.98
MANGAFINDER_AGENT_ALLOW_CLOUD_IMAGES=false
MANGAFINDER_AGENT_PROMPT_VERSION=v8

# 作者动态雷达。启用时 Dockge/Compose 还要设置 COMPOSE_PROFILES=social。
MANGAFINDER_SOCIAL_ENABLED=false
MANGAFINDER_SOCIAL_COLLECTOR_TOKEN=请生成一段至少32位的随机字符串
MANGAFINDER_SOCIAL_SYNC_INTERVAL_MINUTES=120
MANGAFINDER_SOCIAL_EVENT_SYNC_INTERVAL_MINUTES=30
MANGAFINDER_SOCIAL_INITIAL_BACKFILL_DAYS=90
MANGAFINDER_SOCIAL_MAX_POSTS_PER_SYNC=100
MANGAFINDER_SOCIAL_AGENT_ENABLED=true
MANGAFINDER_SOCIAL_AGENT_PROMPT_VERSION=social-zh-v2
MANGAFINDER_SOCIAL_AUTO_CONFIRM_THRESHOLD=0.92
MANGAFINDER_SOCIAL_CANDIDATE_THRESHOLD=0.60
MANGAFINDER_SOCIAL_OCR_ENABLED=true
MANGAFINDER_SOCIAL_OCR_MAX_POSTS_PER_SYNC=12
MANGAFINDER_SOCIAL_OCR_TIMEOUT_SECONDS=30
MANGAFINDER_SOCIAL_DAILY_DIGEST_ENABLED=true
MANGAFINDER_SOCIAL_DAILY_DIGEST_HOUR=20
MANGAFINDER_SOCIAL_DAILY_DIGEST_TIMEZONE=Asia/Shanghai
MANGAFINDER_SOCIAL_DAILY_DIGEST_INITIAL_LOOKBACK_DAYS=7
MANGAFINDER_SOCIAL_DAILY_DIGEST_MIN_IMPORTANCE=normal
MANGAFINDER_SOCIAL_DAILY_DIGEST_MAX_AUTHORS=20
MANGAFINDER_SOCIAL_DAILY_DIGEST_MAX_ITEMS_PER_AUTHOR=3
MANGAFINDER_PUBLIC_BASE_URL=http://192.168.1.2:8000

# X 浏览器会话目录内需放置 storage-state.json，权限建议 0600。
MANGAFINDER_X_SESSION_HOST_DIR=./data/x-session
MANGAFINDER_X_PROXY_URL=
MANGAFINDER_X_USER_AGENT=

# QQ 官方机器人个人私聊；未配置时通知会保留在站内 outbox。
MANGAFINDER_QQ_BOT_ENABLED=false
MANGAFINDER_QQ_BOT_APP_ID=
MANGAFINDER_QQ_BOT_CLIENT_SECRET=
MANGAFINDER_QQ_BOT_USER_OPENID=

# DeepSeek API 示例（密钥只放 .env，不要提交到源码）：
# MANGAFINDER_AGENT_PROVIDER=deepseek
# MANGAFINDER_AGENT_BASE_URL=https://api.deepseek.com
# MANGAFINDER_AGENT_MODEL=deepseek-v4-flash
